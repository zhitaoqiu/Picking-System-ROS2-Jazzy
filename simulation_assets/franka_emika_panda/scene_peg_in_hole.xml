<mujoco model="task_peg_in_hole">
    <include file="panda.xml"/>

    <statistic center="0.3 0 0.4" extent="1"/>

    <visual>
        <headlight diffuse="0.6 0.6 0.6" ambient="0.3 0.3 0.3" specular="0 0 0"/>
        <rgba haze="0.15 0.25 0.35 1"/>
        <global azimuth="120" elevation="-20"/>
    </visual>

    <asset>
        <texture type="skybox" builtin="gradient" rgb1="0.3 0.5 0.7" rgb2="0 0 0" width="512" height="3072"/>
        <texture type="2d" name="groundplane" builtin="checker" mark="edge" rgb1="0.2 0.3 0.4" rgb2="0.1 0.2 0.3"
          markrgb="0.8 0.8 0.8" width="300" height="300"/>
        <material name="groundplane" texture="groundplane" texuniform="true" texrepeat="5 5" reflectance="0.2"/>
    </asset>

    <worldbody>
        <light pos="0 0 1.5" dir="0 0 -1" directional="true"/>
        <geom name="floor" size="0 0 0.05" type="plane" material="groundplane"/>

        <body name="target_hole" pos="0.5 0 0.02">
            <geom name="hole_bottom" type="box" size="0.05 0.05 0.01"
                  pos="0 0 -0.01" rgba="0.2 0.8 0.2 1"/>
            <geom name="wall_front" type="box" size="0.05 0.015 0.02"
                  pos="0  0.035 0.02" rgba="0.6 0.6 0.6 1"
                  solimp="0.95 0.99 0.001" solref="0.008 1"/>
            <geom name="wall_back"  type="box" size="0.05 0.015 0.02"
                  pos="0 -0.035 0.02" rgba="0.6 0.6 0.6 1"
                  solimp="0.95 0.99 0.001" solref="0.008 1"/>
            <geom name="wall_left"  type="box" size="0.02 0.02 0.02"
                  pos="0.03  0 0.02" rgba="0.6 0.6 0.6 1"
                  solimp="0.95 0.99 0.001" solref="0.008 1"/>
            <geom name="wall_right" type="box" size="0.02 0.02 0.02"
                  pos="-0.03 0 0.02" rgba="0.6 0.6 0.6 1"
                  solimp="0.95 0.99 0.001" solref="0.008 1"/>
            <site name="hole_center" pos="0 0 0.01" size="0.005" rgba="1 0 0 0"/>
        </body>
    </worldbody>

    <sensor>
        <force  name="ee_force_sensor"  site="ft_sensor_site"/>
        <torque name="ee_torque_sensor" site="ft_sensor_site"/>
    </sensor>

    <!-- peg 是 hand 的子 geom，不需要任何 contact exclude -->

</mujoco>